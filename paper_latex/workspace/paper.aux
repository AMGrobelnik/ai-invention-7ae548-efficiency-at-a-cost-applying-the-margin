\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Efficiency-quality Pareto frontier on QASPER ($n=223$ questions). Each point represents one retrieval method; x-axis is mean chunks retrieved per question (lower = more efficient); y-axis is token-level F1. The Pareto frontier (dashed line) connects non-dominated methods. MVT-RAG (star marker) lies on the frontier at 1.30 chunks/F1=0.138, between no-RAG and Threshold-0.5. No method achieves equal or higher F1 with equal or fewer chunks.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:fig2}{{2}{6}{Efficiency-quality Pareto frontier on QASPER ($n=223$ questions). Each point represents one retrieval method; x-axis is mean chunks retrieved per question (lower = more efficient); y-axis is token-level F1. The Pareto frontier (dashed line) connects non-dominated methods. MVT-RAG (star marker) lies on the frontier at 1.30 chunks/F1=0.138, between no-RAG and Threshold-0.5. No method achieves equal or higher F1 with equal or fewer chunks}{figure.2}{}}
